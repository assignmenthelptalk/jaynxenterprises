---
import { SITE } from '../config';
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-left">
      <h1 class="hero-title">
        East Africa's trusted source for <em>industrial supplies</em> & fabrication
      </h1>

      <p class="hero-sub">
        From factory tools and pipe fittings to custom-fabricated tanks — Jaynx Enterprises
        delivers everything your operation needs, fast.
      </p>

      <p class="hero-trust">If you need it, we've got it.</p>

      <div class="hero-buttons">
        <a href="/#contact" class="btn btn-primary">
          Request a quote
        </a>
        <a
          href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.ctaWhatsappMessage)}`}
          class="btn btn-secondary"
          target="_blank"
          rel="noopener"
          data-conversion="whatsapp"
        >
          WhatsApp us
        </a>
      </div>
    </div>

    <div class="hero-right">
      <div class="showcase-card">
        <p class="showcase-label">What we supply</p>
        <div class="showcase-grid">
          <a href="/products/fasteners-hardware" class="showcase-item">
            <span class="showcase-icon">🔧</span>
            <span class="showcase-name">Industrial Tools</span>
          </a>
          <a href="/products/piping-valves" class="showcase-item">
            <span class="showcase-icon">🔩</span>
            <span class="showcase-name">Pipe Fittings</span>
          </a>
          <a href="/products/electrical-motors" class="showcase-item">
            <span class="showcase-icon">⚙️</span>
            <span class="showcase-name">Pumps & Motors</span>
          </a>
          <a href="/products/air-pneumatic" class="showcase-item">
            <span class="showcase-icon">🌀</span>
            <span class="showcase-name">Hoses & Couplings</span>
          </a>
          <a href="/products/boiler-steam" class="showcase-item">
            <span class="showcase-icon">🔑</span>
            <span class="showcase-name">Valves & Actuators</span>
          </a>
          <a href="/products/crusher-processing" class="showcase-item">
            <span class="showcase-icon">🏗️</span>
            <span class="showcase-name">Fabrication</span>
          </a>
        </div>
        <div class="showcase-footer">
          <span class="showcase-badge">1,000+ products in stock</span>
          <span class="showcase-badge">Same-day despatch</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: #eef1fb;
    background-image: linear-gradient(135deg, #f5f7ff 0%, #e8eeff 60%, #dde4fc 100%);
    padding: 120px 0 64px;
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    box-sizing: border-box;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(99, 120, 230, 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(99, 120, 230, 0.1) 1px, transparent 1px);
    background-size: 36px 36px;
    mask-image: radial-gradient(ellipse 70% 80% at 80% 30%, black 20%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 70% 80% at 80% 30%, black 20%, transparent 75%);
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    right: -2%;
    top: 50%;
    transform: translateY(-50%);
    width: 52%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle, #c7d3f8 0%, #b8c8f5 40%, transparent 70%);
    opacity: 0.55;
    pointer-events: none;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 48px;
    align-items: center;
    width: 100%;
    position: relative;
    z-index: 1;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-title {
    font-size: clamp(38px, 5.5vw, 64px);
    font-weight: 800;
    color: #111111;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 0;
  }

  .hero-title em {
    font-style: normal;
    color: #e8590c;
  }

  .hero-sub {
    font-size: 18px;
    color: #666666;
    line-height: 1.65;
    max-width: 540px;
    margin-top: 24px;
  }

  .hero-trust {
    font-family: 'Caveat', cursive;
    font-size: 22px;
    font-weight: 600;
    color: #4361ee;
    margin-top: 24px;
  }

  .hero-trust::before {
    content: '<- ';
  }

  .hero-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 28px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    min-height: 50px;
    padding: 0 28px;
    border-radius: 6px;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    border: 2px solid transparent;
    transition: background 0.2s ease, transform 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .btn-primary {
    background: #2563eb;
    color: #ffffff;
    border-color: #2563eb;
  }

  .btn-primary:hover {
    background: #1d4ed8;
    border-color: #1d4ed8;
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: #ffffff;
    color: #111111;
    border-color: #111111;
  }

  .btn-secondary:hover {
    background: #111111;
    color: #ffffff;
    transform: translateY(-2px);
  }

  /* Showcase card */
  .showcase-card {
    background: #ffffff;
    border: 1.5px solid #e2e8f6;
    border-radius: 20px;
    padding: 32px 28px 28px;
    box-shadow: 0 20px 56px rgba(37, 99, 235, 0.12);
    position: relative;
    z-index: 1;
  }

  .showcase-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #2563eb;
    margin-bottom: 20px;
  }

  .showcase-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 24px;
  }

  .showcase-item {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #f4f7ff;
    border: 1px solid #e2e8f6;
    border-radius: 10px;
    padding: 12px 14px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    text-decoration: none;
    color: inherit;
  }

  .showcase-item:hover {
    border-color: #2563eb;
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.1);
  }

  .showcase-icon {
    font-size: 20px;
    flex-shrink: 0;
  }

  .showcase-name {
    font-size: 13px;
    font-weight: 600;
    color: #0e1f3d;
    line-height: 1.3;
  }

  .showcase-footer {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .showcase-badge {
    background: #eef3ff;
    color: #2563eb;
    border: 1px solid #d0dcff;
    border-radius: 999px;
    padding: 5px 12px;
    font-size: 12px;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .hero {
      height: auto;
      min-height: 100vh;
      padding: 100px 0 80px;
      align-items: flex-start;
    }

    .hero-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .hero-right {
      order: -1;
    }

    .hero-title {
      font-size: clamp(32px, 9vw, 40px);
    }

    .hero-sub {
      font-size: 16px;
      max-width: 100%;
    }

    .hero-buttons {
      flex-direction: column;
      width: 100%;
    }

    .btn { width: 100%; }

    .hero-trust { font-size: 20px; }

    .showcase-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 375px) {
    .hero-title { font-size: 34px; }
    .showcase-grid { grid-template-columns: 1fr; }
  }
</style>
