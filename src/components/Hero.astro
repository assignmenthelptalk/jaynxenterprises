---
import { SITE } from '../config';
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-left">
      <h1 class="hero-title">
        East Africa's trusted source for <em>industrial supplies</em> & fabrication
      </h1>

      <p class="hero-sub">
        From factory tools and pipe fittings to custom-fabricated tanks — Jaynx Enterprises
        delivers everything your operation needs, fast.
      </p>

      <p class="hero-trust">If you need it, we've got it.</p>

      <div class="hero-buttons">
        <a href="/#contact" class="btn btn-primary">
          Request a quote
        </a>
        <a
          href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.ctaWhatsappMessage)}`}
          class="btn btn-secondary"
          target="_blank"
          rel="noopener"
          data-conversion="whatsapp"
        >
          WhatsApp us
        </a>
      </div>
    </div>

    <div class="hero-right">
      <div class="hero-visual">
        <!-- decorative blob -->
        <div class="visual-blob"></div>

        <!-- main product image -->
        <div class="visual-main">
          <img
            src="/categories/electrical-motors.webp"
            alt="Industrial motors and electrical equipment"
            loading="eager"
            width="300"
            height="380"
          />
        </div>

        <!-- floating left card -->
        <div class="visual-float visual-float-left">
          <div class="float-icon">
            <img src="/categories/piping-valves.webp" alt="" />
          </div>
          <span>Piping &amp; Valves</span>
        </div>

        <!-- floating right card -->
        <div class="visual-float visual-float-right">
          <div class="float-icon">
            <img src="/categories/bearings.webp" alt="" />
          </div>
          <span>Bearings</span>
        </div>

        <!-- trust pill -->
        <div class="visual-pill">
          <div class="pill-thumbs">
            <img src="/categories/fasteners-hardware.webp" alt="" />
            <img src="/categories/compressor-parts.webp" alt="" />
            <img src="/categories/conveyor-belts.webp" alt="" />
          </div>
          <div class="pill-copy">
            <strong>500+ businesses</strong>
            <span>served across Kenya</span>
          </div>
        </div>

        <!-- mini product icon grid -->
        <div class="visual-mini-grid">
          <img src="/categories/seals-gaskets.webp" alt="" />
          <img src="/categories/v-belts.webp" alt="" />
          <img src="/categories/lubricants.webp" alt="" />
          <img src="/categories/sensors-controls.webp" alt="" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: #eef1fb;
    background-image: linear-gradient(135deg, #f5f7ff 0%, #e8eeff 60%, #dde4fc 100%);
    padding: 120px 0 64px;
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    box-sizing: border-box;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(99, 120, 230, 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(99, 120, 230, 0.1) 1px, transparent 1px);
    background-size: 36px 36px;
    mask-image: radial-gradient(ellipse 70% 80% at 80% 30%, black 20%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 70% 80% at 80% 30%, black 20%, transparent 75%);
    pointer-events: none;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 48px;
    align-items: center;
    width: 100%;
    position: relative;
    z-index: 1;
  }

  /* ── Left side ── */
  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-title {
    font-size: clamp(38px, 5.5vw, 64px);
    font-weight: 800;
    color: #111111;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 0;
  }

  .hero-title em {
    font-style: normal;
    color: #e8590c;
  }

  .hero-sub {
    font-size: 18px;
    color: #666666;
    line-height: 1.65;
    max-width: 540px;
    margin-top: 24px;
  }

  .hero-trust {
    font-family: 'Caveat', cursive;
    font-size: 22px;
    font-weight: 600;
    color: #4361ee;
    margin-top: 24px;
  }

  .hero-trust::before {
    content: '<- ';
  }

  .hero-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 28px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    min-height: 50px;
    padding: 0 28px;
    border-radius: 6px;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    border: 2px solid transparent;
    transition: background 0.2s ease, transform 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .btn-primary {
    background: #2563eb;
    color: #ffffff;
    border-color: #2563eb;
  }

  .btn-primary:hover {
    background: #1d4ed8;
    border-color: #1d4ed8;
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: #ffffff;
    color: #111111;
    border-color: #111111;
  }

  .btn-secondary:hover {
    background: #111111;
    color: #ffffff;
    transform: translateY(-2px);
  }

  /* ── Right side: image composition ── */
  .hero-right {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-visual {
    position: relative;
    width: 380px;
    height: 468px;
    flex-shrink: 0;
  }

  /* decorative blue circle blob */
  .visual-blob {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -54%);
    width: 70%;
    aspect-ratio: 1;
    background: #4361ee;
    border-radius: 50%;
    opacity: 0.25;
    z-index: 0;
  }

  /* main tall product image */
  .visual-main {
    position: absolute;
    top: 4%;
    left: 50%;
    transform: translateX(-50%);
    width: 64%;
    height: 78%;
    border-radius: 24px;
    overflow: hidden;
    z-index: 1;
    box-shadow:
      0 28px 60px rgba(37, 99, 235, 0.22),
      0 8px 20px rgba(0, 0, 0, 0.1);
  }

  .visual-main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* floating glass cards */
  .visual-float {
    position: absolute;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.95);
    border-radius: 20px;
    padding: 10px 10px 8px;
    box-shadow:
      0 10px 30px rgba(37, 99, 235, 0.14),
      0 2px 6px rgba(0, 0, 0, 0.06);
    animation: float-y 3s ease-in-out infinite;
  }

  .visual-float-left {
    left: -6px;
    top: 28%;
    animation-delay: 0s;
  }

  .visual-float-right {
    right: -6px;
    top: 20%;
    animation-delay: 1.5s;
  }

  .float-icon {
    width: 58px;
    height: 58px;
    border-radius: 15px;
    overflow: hidden;
    background: #f0f4ff;
    box-shadow: 0 2px 8px rgba(67, 97, 238, 0.18);
  }

  .float-icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .visual-float span {
    font-size: 10px;
    font-weight: 700;
    color: #0e1f3d;
    text-align: center;
    line-height: 1.25;
    max-width: 72px;
  }

  /* trust / stats pill */
  .visual-pill {
    position: absolute;
    bottom: 15%;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.95);
    border-radius: 999px;
    padding: 8px 16px 8px 8px;
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.11);
    white-space: nowrap;
  }

  .pill-thumbs {
    display: flex;
    align-items: center;
  }

  .pill-thumbs img {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid #fff;
    object-fit: cover;
    display: block;
    margin-left: -8px;
  }

  .pill-thumbs img:first-child {
    margin-left: 0;
  }

  .pill-copy {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }

  .pill-copy strong {
    font-size: 12px;
    font-weight: 700;
    color: #0e1f3d;
  }

  .pill-copy span {
    font-size: 10px;
    color: #666;
  }

  /* mini product icon grid (2 × 2) */
  .visual-mini-grid {
    position: absolute;
    bottom: 0;
    right: 0;
    z-index: 3;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 4px;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.95);
    border-radius: 18px;
    padding: 7px;
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.08);
  }

  .visual-mini-grid img {
    width: 36px;
    height: 36px;
    border-radius: 9px;
    object-fit: cover;
    display: block;
  }

  /* gentle floating animation */
  @keyframes float-y {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-8px); }
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero-visual {
      width: 320px;
      height: 395px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      height: auto;
      min-height: 100vh;
      padding: 100px 0 80px;
      align-items: flex-start;
    }

    .hero-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .hero-right {
      order: -1;
    }

    .hero-visual {
      width: 290px;
      height: 358px;
      margin: 0 auto;
    }

    .visual-float-left  { left: -12px; }
    .visual-float-right { right: -12px; }

    .hero-title {
      font-size: clamp(32px, 9vw, 40px);
    }

    .hero-sub {
      font-size: 16px;
      max-width: 100%;
    }

    .hero-buttons {
      flex-direction: column;
      width: 100%;
    }

    .btn { width: 100%; }

    .hero-trust { font-size: 20px; }
  }

  @media (max-width: 375px) {
    .hero-title { font-size: 34px; }

    .hero-visual {
      width: 260px;
      height: 320px;
    }
  }
</style>
