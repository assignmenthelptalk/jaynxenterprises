---
import { SITE } from '../config';
import { categories } from '../data/products';

const year = new Date().getFullYear();
const col1 = categories.slice(0, 8);
const col2 = categories.slice(8);
---

<footer class="footer">
  <div class="container footer-main">

    <!-- Brand -->
    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <div class="footer-logo-icon">J</div>
        <span>{SITE.name}</span>
      </a>
      <p class="footer-tagline">{SITE.tagline}</p>

      <div class="footer-contact-block">
        <a href={`tel:${SITE.phone}`} class="footer-contact-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8a19.79 19.79 0 01-3.07-8.68A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          {SITE.phone}
        </a>
        <a href={`mailto:${SITE.email}`} class="footer-contact-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12a2 2 0 01-2 2H4a2 2 0 01-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,12 2,6"/></svg>
          {SITE.email}
        </a>
        <a
          href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.ctaWhatsappMessage)}`}
          class="footer-wa-btn"
          target="_blank"
          rel="noopener"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" width="15" height="15" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp Us
        </a>
      </div>

      <div class="footer-social">
        {SITE.social.twitter && (
          <a href={SITE.social.twitter} target="_blank" rel="noopener" aria-label="Twitter/X">
            <svg viewBox="0 0 24 24" fill="currentColor" width="17" height="17"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/></svg>
          </a>
        )}
        {SITE.social.instagram && (
          <a href={SITE.social.instagram} target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="currentColor" width="17" height="17"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        )}
        {SITE.social.linkedin && (
          <a href={SITE.social.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor" width="17" height="17"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        )}
      </div>
    </div>

    <!-- Categories col 1 -->
    <nav class="footer-nav" aria-label="Product categories part 1">
      <p class="footer-nav-title">
        <a href="/products" class="footer-nav-title-link">Products</a>
      </p>
      {col1.map(cat => (
        <a href={`/products/${cat.slug}`} class="footer-cat-link">
          <span aria-hidden="true">{cat.icon}</span>
          {cat.name}
        </a>
      ))}
    </nav>

    <!-- Categories col 2 -->
    <nav class="footer-nav footer-nav--cats" aria-label="Product categories part 2">
      <p class="footer-nav-title">&nbsp;</p>
      {col2.map(cat => (
        <a href={`/products/${cat.slug}`} class="footer-cat-link">
          <span aria-hidden="true">{cat.icon}</span>
          {cat.name}
        </a>
      ))}
    </nav>

    <!-- Company / Quick links -->
    <nav class="footer-nav" aria-label="Quick links">
      <p class="footer-nav-title">Quick Links</p>
      <a href="/#services">Services</a>
      <a href="/#industries">Industries</a>
      <a href="/products">All Categories</a>
      <a href="/contact">Request a Quote</a>
      <a href="/#contact">Contact Us</a>
    </nav>

  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>© {year} {SITE.name}. All rights reserved. Nairobi, Kenya.</p>
      <div class="footer-bottom-links">
        <a href={`mailto:${SITE.email}`}>Email</a>
        <a href="/contact">Get a Quote</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #0f172a;
    border-top: none;
  }

  .footer-main {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 48px 40px;
    padding-top: 64px;
    padding-bottom: 56px;
    align-items: start;
  }

  /* Brand */
  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 14px;
  }

  .footer-logo-icon {
    width: 36px;
    height: 36px;
    background: #2563eb;
    color: #fff;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 800;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .footer-logo span {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    color: #fff;
  }

  .footer-tagline {
    font-size: 13.5px;
    color: #94a3b8;
    line-height: 1.65;
    max-width: 240px;
    margin-bottom: 24px;
  }

  .footer-contact-block {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 24px;
  }

  .footer-contact-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13.5px;
    color: #cbd5e1;
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-contact-link:hover { color: #fff; }

  .footer-wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    color: #4ade80;
    background: rgba(74,222,128,0.08);
    border: 1px solid rgba(74,222,128,0.25);
    border-radius: 6px;
    padding: 7px 14px;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    width: fit-content;
  }

  .footer-wa-btn:hover { background: rgba(74,222,128,0.15); color: #86efac; }

  .footer-social {
    display: flex;
    gap: 14px;
    margin-top: 4px;
  }

  .footer-social a {
    color: #475569;
    transition: color 0.15s;
    display: flex;
    align-items: center;
  }

  .footer-social a:hover { color: #94a3b8; }

  /* Nav columns */
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-nav-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #64748b;
    margin-bottom: 6px;
  }

  .footer-nav-title-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-nav-title-link:hover { color: #94a3b8; }

  .footer-nav a:not(.footer-nav-title-link) {
    font-size: 13.5px;
    color: #94a3b8;
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-nav a:not(.footer-nav-title-link):hover { color: #e2e8f0; }

  .footer-cat-link {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 13px !important;
  }

  .footer-cat-link span { font-size: 14px; flex-shrink: 0; }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid #1e293b;
    padding: 20px 0;
  }

  .footer-bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }

  .footer-bottom-inner p {
    font-size: 12.5px;
    color: #475569;
  }

  .footer-bottom-links { display: flex; gap: 24px; }

  .footer-bottom-links a {
    font-size: 12.5px;
    color: #475569;
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-bottom-links a:hover { color: #94a3b8; }

  /* Responsive */
  @media (max-width: 1000px) {
    .footer-main { grid-template-columns: 1fr 1fr; gap: 36px 32px; }
    .footer-brand { grid-column: 1 / -1; }
  }

  @media (max-width: 560px) {
    .footer-main { grid-template-columns: 1fr 1fr; gap: 28px 20px; }
    .footer-bottom-inner { flex-direction: column; align-items: flex-start; }
  }

  @media (max-width: 360px) {
    .footer-main { grid-template-columns: 1fr; }
  }
</style>