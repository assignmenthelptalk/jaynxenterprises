---
import { SITE } from '../config';
---

<div class="nav-overlay" id="nav-overlay" aria-hidden="true"></div>
<header class="navbar" id="navbar">
  <div class="container navbar-inner">
    <a href="/" class="logo">
      <span class="logo-icon" aria-hidden="true">J</span>
      {SITE.name}
    </a>

    <nav class="nav-links" id="nav-links">
      <a href="/products" class="menu-link">Products</a>
      <a href="/#services" class="menu-link">Services</a>
      <a href="/#industries" class="menu-link">Industries</a>
      <a href="/#contact" class="menu-link">Contact</a>
    </nav>

    <a
      href={`https://wa.me/${SITE.whatsapp}`}
      class="nav-whatsapp"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Chat on WhatsApp"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
        <path d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.933 7.933 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.898 7.898 0 0 0 13.6 2.326zM7.994 14.521a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592zm3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.729.729 0 0 0-.529.247c-.182.198-.691.677-.691 1.654 0 .977.71 1.916.81 2.049.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232z"/>
      </svg>
      {SITE.phone}
    </a>

    <a href="/#contact" class="btn btn-primary nav-cta">
      {SITE.ctaText}
    </a>

    <button class="mobile-toggle" id="mobile-toggle" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<script>
  const navbar   = document.getElementById('navbar');
  const toggle   = document.getElementById('mobile-toggle');
  const navLinks = document.getElementById('nav-links');
  const overlay  = document.getElementById('nav-overlay');

  function openMenu() {
    navLinks?.classList.add('open');
    toggle?.classList.add('open');
    overlay?.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    navLinks?.classList.remove('open');
    toggle?.classList.remove('open');
    overlay?.classList.remove('open');
    document.body.style.overflow = '';
  }

  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 60);
  });

  toggle?.addEventListener('click', () => {
    navLinks?.classList.contains('open') ? closeMenu() : openMenu();
  });

  overlay?.addEventListener('click', closeMenu);

  navLinks?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: #ffffff;
    border-bottom: 1px solid #ebebeb;
    box-shadow: 0 1px 0 rgba(0,0,0,0.04);
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    gap: 0;
    height: 72px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    color: #111111;
    letter-spacing: -0.01em;
    flex-shrink: 0;
    margin-right: 40px;
    text-decoration: none;
  }

  .logo-icon {
    width: 32px;
    height: 32px;
    background: #2563eb;
    color: #ffffff;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    font-weight: 800;
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-links a {
    font-size: 14px;
    font-weight: 500;
    color: #2563eb;
    padding: 6px 12px;
    border-radius: 6px;
    text-decoration: none;
    transition: color 0.15s ease, background 0.15s ease;
  }

  .nav-links a:hover {
    color: #1d4ed8;
    background: #f4f4f5;
  }

  .nav-whatsapp {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-left: auto;
    padding: 8px 14px;
    font-size: 13px;
    font-weight: 600;
    color: #16a34a;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 6px;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .nav-whatsapp:hover {
    background: #dcfce7;
    color: #15803d;
  }

  .nav-cta {
    padding: 10px 20px;
    font-size: 14px;
    flex-shrink: 0;
    border-radius: 6px;
  }

  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }

  .nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 98;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .mobile-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--dark);
    transition: transform var(--transition), opacity var(--transition);
  }

  .mobile-toggle.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .mobile-toggle.open span:nth-child(2) { opacity: 0; }
  .mobile-toggle.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  @media (max-width: 768px) {
    .navbar-inner { gap: 10px; }

    .mobile-toggle {
      display: flex;
      order: 3;
      margin-left: 0;
      flex-shrink: 0;
    }

    .nav-whatsapp { display: none; }

    .nav-cta {
      order: 2;
      margin-left: auto;
      font-size: 12px;
      padding: 8px 12px;
      min-height: 42px;
      white-space: nowrap;
      flex-shrink: 1;
    }

    .logo {
      margin-right: 0;
      min-width: 0;
      gap: 8px;
      font-size: 15px;
      flex: 1 1 auto;
    }

    .logo-icon {
      width: 30px;
      height: 30px;
      font-size: 14px;
    }

    .logo, .logo span { white-space: nowrap; }

    .nav-links {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: min(280px, 80vw);
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      background: #ffffff;
      padding: 88px 0 32px;
      margin: 0;
      transform: translateX(100%);
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: -8px 0 32px rgba(0, 0, 0, 0.4);
      z-index: 99;
    }

    .nav-links.open {
      display: flex;
      transform: translateX(0);
    }

    .nav-links a {
      width: 100%;
      padding: 16px 28px;
      font-size: 17px;
      border-radius: 0;
      border-bottom: 1px solid #f0f0f0;
      color: #2563eb;
    }

    .nav-overlay { display: block; }
    .nav-overlay.open { opacity: 1; pointer-events: auto; }
  }

  @media (max-width: 480px) {
    .nav-cta { padding: 8px 10px; font-size: 11px; }
    .logo { font-size: 14px; }
  }
</style>
