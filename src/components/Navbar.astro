---
import { SITE } from '../config';
import { categories } from '../data/products';
---

<div class="nav-overlay" id="nav-overlay" aria-hidden="true"></div>
<header class="navbar" id="navbar">
  <div class="container navbar-inner">
    <a href="/" class="logo">
      <span class="logo-icon" aria-hidden="true">J</span>
      {SITE.name}
    </a>

    <nav class="nav-links" id="nav-links">
      <!-- Products dropdown -->
      <div class="nav-dropdown" id="products-dropdown">
        <button
          class="menu-link dropdown-trigger"
          id="products-btn"
          aria-expanded="false"
          aria-haspopup="true"
        >
          Products
          <svg class="chevron" viewBox="0 0 12 8" fill="none" width="10" height="10" aria-hidden="true">
            <path d="M1 1.5l5 5 5-5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <div class="dropdown-panel" id="products-panel" role="menu" aria-labelledby="products-btn">
          <div class="dropdown-header">
            <span class="dropdown-heading">Product Categories</span>
            <a href="/products" class="dropdown-all">View all →</a>
          </div>
          <div class="dropdown-grid">
            {categories.map(cat => (
              <a href={`/products/${cat.slug}`} class="dropdown-item" role="menuitem">
                <span class="dropdown-icon" aria-hidden="true">{cat.icon}</span>
                <span class="dropdown-name">{cat.name}</span>
              </a>
            ))}
          </div>
          <div class="dropdown-footer">
            <a href="/contact" class="dropdown-quote-link">
              Can't find a part? Request a quote →
            </a>
          </div>
        </div>

        <!-- Mobile sub-list (expanded inline) -->
        <div class="mobile-cat-list" id="mobile-cat-list" hidden>
          {categories.map(cat => (
            <a href={`/products/${cat.slug}`} class="mobile-cat-link">
              <span aria-hidden="true">{cat.icon}</span>
              {cat.name}
            </a>
          ))}
          <a href="/products" class="mobile-cat-link mobile-cat-all">Browse all categories →</a>
        </div>
      </div>

      <a href="/services" class="menu-link">Services</a>
      <a href="/industries" class="menu-link">Industries</a>
      <a href="/contact" class="menu-link">Contact</a>
    </nav>

    <a
      href={`mailto:${SITE.email}`}
      class="nav-email"
      aria-label="Email us"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
        <path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1H2zm13 2.383-4.708 2.825L15 11.105V5.383zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741zM1 11.105l4.708-2.897L1 5.383v5.722z"/>
      </svg>
      {SITE.email}
    </a>

    <a
      href={`https://wa.me/${SITE.whatsapp}`}
      class="nav-whatsapp"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Chat on WhatsApp"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
        <path d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.933 7.933 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.898 7.898 0 0 0 13.6 2.326zM7.994 14.521a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592zm3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.729.729 0 0 0-.529.247c-.182.198-.691.677-.691 1.654 0 .977.71 1.916.81 2.049.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232z"/>
      </svg>
      {SITE.phone}
    </a>

    <a href="/contact" class="btn btn-primary nav-cta">
      {SITE.ctaText}
    </a>

    <button class="mobile-toggle" id="mobile-toggle" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<script>
  const navbar    = document.getElementById('navbar');
  const toggle    = document.getElementById('mobile-toggle');
  const navLinks  = document.getElementById('nav-links');
  const overlay   = document.getElementById('nav-overlay');
  const prodBtn   = document.getElementById('products-btn');
  const prodPanel = document.getElementById('products-panel');
  const mobileCat = document.getElementById('mobile-cat-list');
  const prodDrop  = document.getElementById('products-dropdown');

  // ── Desktop dropdown (hover + keyboard) ──────────────────────
  let closeTimer: ReturnType<typeof setTimeout>;

  function openDropdown() {
    clearTimeout(closeTimer);
    prodPanel?.removeAttribute('hidden');
    prodBtn?.setAttribute('aria-expanded', 'true');
    prodDrop?.classList.add('open');
  }

  function closeDropdown() {
    closeTimer = setTimeout(() => {
      prodPanel?.setAttribute('hidden', '');
      prodBtn?.setAttribute('aria-expanded', 'false');
      prodDrop?.classList.remove('open');
    }, 120);
  }

  prodDrop?.addEventListener('mouseenter', openDropdown);
  prodDrop?.addEventListener('mouseleave', closeDropdown);
  prodPanel?.addEventListener('mouseenter', () => clearTimeout(closeTimer));
  prodPanel?.addEventListener('mouseleave', closeDropdown);

  prodBtn?.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      prodPanel?.hasAttribute('hidden') ? openDropdown() : closeDropdown();
    }
    if (e.key === 'Escape') closeDropdown();
  });

  document.addEventListener('click', (e) => {
    if (!prodDrop?.contains(e.target as Node)) closeDropdown();
  });

  // Close on item click (desktop)
  prodPanel?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', closeDropdown);
  });

  // ── Mobile toggle ──────────────────────────────────────────────
  function openMenu() {
    navLinks?.classList.add('open');
    toggle?.classList.add('open');
    overlay?.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    navLinks?.classList.remove('open');
    toggle?.classList.remove('open');
    overlay?.classList.remove('open');
    document.body.style.overflow = '';
    // collapse mobile categories too
    mobileCat?.setAttribute('hidden', '');
    prodBtn?.setAttribute('aria-expanded', 'false');
    prodDrop?.classList.remove('mobile-open');
  }

  // Mobile Products button toggles sub-list instead of navigating
  prodBtn?.addEventListener('click', () => {
    const isMobile = window.innerWidth <= 768;
    if (!isMobile) return;
    const isOpen = !mobileCat?.hasAttribute('hidden');
    if (isOpen) {
      mobileCat?.setAttribute('hidden', '');
      prodBtn.setAttribute('aria-expanded', 'false');
      prodDrop?.classList.remove('mobile-open');
    } else {
      mobileCat?.removeAttribute('hidden');
      prodBtn.setAttribute('aria-expanded', 'true');
      prodDrop?.classList.add('mobile-open');
    }
  });

  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 60);
  });

  toggle?.addEventListener('click', () => {
    navLinks?.classList.contains('open') ? closeMenu() : openMenu();
  });

  overlay?.addEventListener('click', closeMenu);

  // Close menu on non-dropdown link click
  navLinks?.querySelectorAll('a:not(.dropdown-item):not(.mobile-cat-link)').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Close menu when a mobile category link is clicked
  mobileCat?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Hide panel on page load (it's visible in SSR)
  prodPanel?.setAttribute('hidden', '');
</script>

<style>
  .navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: #ffffff;
    border-bottom: 1px solid #ebebeb;
    box-shadow: 0 1px 0 rgba(0,0,0,0.04);
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    height: 72px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    color: #111111;
    letter-spacing: -0.01em;
    flex-shrink: 0;
    margin-right: 32px;
    text-decoration: none;
  }

  .logo-icon {
    width: 32px; height: 32px;
    background: #2563eb;
    color: #ffffff;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    font-weight: 800;
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .menu-link {
    font-size: 14px;
    font-weight: 500;
    color: #2563eb;
    padding: 6px 12px;
    border-radius: 6px;
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    display: flex;
    align-items: center;
    gap: 4px;
    white-space: nowrap;
  }

  .menu-link:hover { color: #1d4ed8; background: #f4f4f5; }

  .chevron {
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  /* ── Desktop dropdown ────────────────────────────────────── */
  .nav-dropdown { position: relative; }

  .dropdown-panel {
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%);
    width: 560px;
    background: #ffffff;
    border: 1.5px solid #e5e7eb;
    border-radius: 14px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.12);
    padding: 0;
    z-index: 200;
    animation: dropIn 0.15s ease;
    overflow: hidden;
  }

  @keyframes dropIn {
    from { opacity: 0; transform: translateX(-50%) translateY(-6px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  .nav-dropdown.open .chevron { transform: rotate(180deg); }

  .dropdown-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px 12px;
    border-bottom: 1px solid #f0f0f0;
  }

  .dropdown-heading {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #888;
  }

  .dropdown-all {
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
  }

  .dropdown-all:hover { text-decoration: underline; }

  .dropdown-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    padding: 10px;
  }

  .dropdown-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 12px 8px;
    border-radius: 8px;
    text-decoration: none;
    color: var(--dark);
    text-align: center;
    transition: background 0.15s;
    font-size: 12px;
    font-weight: 600;
    line-height: 1.3;
  }

  .dropdown-item:hover { background: #f4f7ff; color: var(--accent); }

  .dropdown-icon { font-size: 22px; line-height: 1; }

  .dropdown-name { font-size: 11.5px; }

  .dropdown-footer {
    padding: 10px 18px 12px;
    border-top: 1px solid #f0f0f0;
  }

  .dropdown-quote-link {
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
  }

  .dropdown-quote-link:hover { color: var(--accent); }

  /* Mobile sub-list hidden on desktop */
  .mobile-cat-list { display: none; }

  /* ── Right-side elements ──────────────────────────────────── */
  .nav-whatsapp {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-left: 8px;
    padding: 8px 14px;
    font-size: 13px;
    font-weight: 600;
    color: #16a34a;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 6px;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.15s, color 0.15s;
  }

  .nav-whatsapp:hover { background: #dcfce7; color: #15803d; }

  .nav-email {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-left: auto;
    padding: 8px 14px;
    font-size: 13px;
    font-weight: 600;
    color: #2563eb;
    background: #eff6ff;
    border: 1px solid #bfdbfe;
    border-radius: 6px;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.15s, color 0.15s;
  }

  .nav-email:hover { background: #dbeafe; color: #1d4ed8; }

  .nav-cta {
    padding: 10px 20px;
    font-size: 14px;
    flex-shrink: 0;
    border-radius: 6px;
    margin-left: 10px;
  }

  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }

  .mobile-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--dark);
    transition: transform var(--transition), opacity var(--transition);
  }

  .mobile-toggle.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .mobile-toggle.open span:nth-child(2) { opacity: 0; }
  .mobile-toggle.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 98;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  /* ── Mobile ────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .navbar-inner { gap: 10px; }

    .mobile-toggle { display: flex; order: 3; margin-left: 0; flex-shrink: 0; }
    .nav-whatsapp  { display: none; }
    .nav-email     { display: none; }

    .nav-cta {
      order: 2;
      margin-left: auto;
      font-size: 12px;
      padding: 8px 12px;
      min-height: 42px;
      white-space: nowrap;
      flex-shrink: 1;
    }

    .logo {
      margin-right: 0;
      min-width: 0;
      gap: 8px;
      font-size: 15px;
      flex: 1 1 auto;
    }

    .logo-icon { width: 30px; height: 30px; font-size: 14px; }
    .logo, .logo span { white-space: nowrap; }

    .nav-links {
      position: fixed;
      top: 0; right: 0; bottom: 0;
      width: min(300px, 80vw);
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      background: #ffffff;
      padding: 88px 0 32px;
      margin: 0;
      transform: translateX(100%);
      transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
      box-shadow: -8px 0 32px rgba(0,0,0,0.4);
      z-index: 99;
      overflow-y: auto;
    }

    .nav-links.open { display: flex; transform: translateX(0); }

    /* Desktop dropdown panel hidden on mobile */
    .dropdown-panel { display: none !important; }

    /* Mobile trigger looks like a full-width link */
    .dropdown-trigger {
      width: 100%;
      padding: 16px 28px;
      font-size: 17px;
      border-radius: 0;
      border-bottom: 1px solid #f0f0f0;
      color: #2563eb;
      justify-content: space-between;
    }

    .nav-dropdown.mobile-open .chevron { transform: rotate(180deg); }

    /* Other nav links */
    .nav-links > a.menu-link {
      width: 100%;
      padding: 16px 28px;
      font-size: 17px;
      border-radius: 0;
      border-bottom: 1px solid #f0f0f0;
      color: #2563eb;
    }

    /* Mobile sub-list */
    .mobile-cat-list {
      display: flex;
      flex-direction: column;
      width: 100%;
      background: #f7f9ff;
      border-bottom: 1px solid #e5e7eb;
    }

    .mobile-cat-link {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 28px 12px 36px;
      font-size: 14px;
      font-weight: 500;
      color: var(--dark);
      text-decoration: none;
      border-bottom: 1px solid #eef0f4;
      transition: background 0.12s, color 0.12s;
    }

    .mobile-cat-link:hover { background: #eef3ff; color: var(--accent); }
    .mobile-cat-all { font-weight: 700; color: var(--accent); border-bottom: none; padding-top: 14px; padding-bottom: 14px; }

    .nav-overlay { display: block; }
    .nav-overlay.open { opacity: 1; pointer-events: auto; }
  }

  @media (max-width: 480px) {
    .nav-cta { padding: 8px 10px; font-size: 11px; }
    .logo { font-size: 14px; }
  }
</style>