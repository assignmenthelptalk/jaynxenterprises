---
import type { Product } from '../data/products';

interface Props {
  product: Product;
  categorySlug: string;
}
const { product, categorySlug } = Astro.props;
const img = product.image ?? `/categories/${categorySlug}.webp`;
---

<div class="pc">
  <a href={`/products/${categorySlug}/${product.id}`} class="pc-img">
    <img src={img} alt={product.name} width="280" height="180" loading="lazy" />
  </a>
  <div class="pc-body">
    <p class="pc-name">{product.name}</p>
    <p class="pc-desc">{product.description}</p>
    <div class="pc-btns">
      <a href={`/products/${categorySlug}/${product.id}`} class="pc-btn pc-btn--outline">Details</a>
      <a href="/#contact" class="pc-btn pc-btn--primary">Get Quote</a>
    </div>
  </div>
</div>

<style>
  .pc {
    background: #fff;
    border: 1.5px solid #e5e5e5;
    border-radius: 10px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .pc:hover {
    box-shadow: 0 8px 24px rgba(37, 99, 235, 0.12);
    transform: translateY(-3px);
  }

  .pc-img {
    display: block;
    height: 160px;
    overflow: hidden;
    background: #f0f4ff;
    flex-shrink: 0;
  }

  .pc-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .pc:hover .pc-img img {
    transform: scale(1.06);
  }

  .pc-body {
    padding: 12px 14px 14px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 6px;
  }

  .pc-name {
    font-size: 13px;
    font-weight: 700;
    color: #111;
    line-height: 1.35;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .pc-desc {
    font-size: 11.5px;
    color: #666;
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .pc-btns {
    display: flex;
    gap: 6px;
    margin-top: 8px;
  }

  .pc-btn {
    flex: 1;
    min-height: 32px;
    border-radius: 6px;
    font-size: 11.5px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    border: 1.5px solid transparent;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    padding: 0 6px;
  }

  .pc-btn--outline {
    border-color: #111;
    color: #111;
    background: transparent;
  }

  .pc-btn--outline:hover {
    background: #111;
    color: #fff;
  }

  .pc-btn--primary {
    background: #e8590c;
    color: #fff;
    border-color: #e8590c;
  }

  .pc-btn--primary:hover {
    background: #c94c08;
    border-color: #c94c08;
  }
</style>
