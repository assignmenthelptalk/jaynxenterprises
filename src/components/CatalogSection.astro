---
import type { Category, Product } from '../data/products';
import ProductCard from './ProductCard.astro';

interface Props {
  category: Category;
  products: Product[];
}
const { category, products } = Astro.props;
const shown = products.slice(0, 4);
const extra = products.length - 4;
---

<section class="cs" id={category.slug}>
  <div class="container">
    <div class="cs-hdr">
      <div class="cs-hdr-l">
        <div class="cs-thumb">
          <img
            src={`/categories/${category.slug}.webp`}
            alt=""
            width="44"
            height="44"
            loading="lazy"
          />
        </div>
        <div>
          <h2 class="cs-title">{category.name}</h2>
          <p class="cs-count">{products.length} product{products.length !== 1 ? 's' : ''} available</p>
        </div>
      </div>
      <a href={`/products/${category.slug}`} class="cs-all">View all →</a>
    </div>

    <div class="cs-grid">
      {shown.map(p => (
        <ProductCard product={p} categorySlug={category.slug} />
      ))}
    </div>

    {extra > 0 && (
      <div class="cs-more">
        <a href={`/products/${category.slug}`} class="cs-more-link">
          +{extra} more — view all {category.name} →
        </a>
      </div>
    )}
  </div>
</section>

<style>
  .cs {
    padding: 36px 0 28px;
    border-bottom: 1px solid #e8e8e8;
  }

  .cs:last-of-type {
    border-bottom: none;
  }

  .cs-hdr {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 18px;
  }

  .cs-hdr-l {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .cs-thumb {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
    border: 1.5px solid #e5e5e5;
    background: #f4f7ff;
  }

  .cs-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cs-title {
    font-size: 17px;
    font-weight: 800;
    color: #111;
    margin: 0 0 2px;
    line-height: 1.2;
  }

  .cs-count {
    font-size: 11.5px;
    color: #666;
    margin: 0;
  }

  .cs-all {
    font-size: 13px;
    font-weight: 600;
    color: #2563eb;
    text-decoration: none;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .cs-all:hover { text-decoration: underline; }

  .cs-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .cs-more {
    margin-top: 14px;
    text-align: center;
  }

  .cs-more-link {
    font-size: 13px;
    font-weight: 600;
    color: #2563eb;
    text-decoration: none;
  }

  .cs-more-link:hover { text-decoration: underline; }

  @media (max-width: 900px) {
    .cs-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 640px) {
    .cs-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .cs-title { font-size: 15px; }
  }
</style>
