---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Industrial Services — Spare Parts Sourcing & Supply | Jaynx Enterprises Kenya"
  description="Jaynx Enterprises offers industrial spare parts supply, machine component sourcing, and equipment support across Kenya and East Africa. Request a quote today."
>
  <Navbar />

  <div class="page-wrap">

    <!-- Hero -->
    <section class="svc-hero">
      <div class="container">
        <span class="section-label">What We Do</span>
        <h1 class="svc-hero-title">Industrial services built for<br/>East African operations</h1>
        <p class="svc-hero-sub">From one-off spare parts to bulk ongoing supply — we source fast, deliver reliably, and keep your machines running.</p>
        <div class="svc-hero-btns">
          <a href="/contact" class="btn btn-primary">Request a Quote</a>
          <a href="/products" class="btn btn-outline">Browse Products</a>
        </div>
      </div>
    </section>

    <!-- Core services grid -->
    <section class="section container">
      <span class="section-label">Core Services</span>
      <h2 class="section-title">Three ways we serve you</h2>

      <div class="core-grid">

        <div class="core-card">
          <div class="core-icon">⚙️</div>
          <h3>Spare Parts Supply</h3>
          <p>We stock and source conveyor belts, bearings, seals, filters, v-belts, lubricants, and 100+ other consumables — all available on request, no minimum order.</p>
          <ul class="core-list">
            <li>Conveyor belts &amp; lagging</li>
            <li>SKF, FAG &amp; NSK bearings</li>
            <li>V-belts &amp; timing belts</li>
            <li>Seals, O-rings &amp; gaskets</li>
            <li>Diesel, oil &amp; air filters</li>
            <li>Industrial lubricants</li>
          </ul>
          <a href="/products/conveyor-belts" class="core-link">Browse spare parts →</a>
        </div>

        <div class="core-card featured">
          <div class="core-badge">Most Requested</div>
          <div class="core-icon">🏭</div>
          <h3>Machine &amp; Process Equipment</h3>
          <p>Critical parts for motors, compressors, crushers, separators, boilers, and control systems — sourced by part number or machine model.</p>
          <ul class="core-list">
            <li>Electrical motors &amp; accessories</li>
            <li>Compressor parts &amp; air tools</li>
            <li>Crusher &amp; processing parts</li>
            <li>Separator &amp; decanter spares</li>
            <li>Boiler &amp; steam system parts</li>
            <li>Sensors, controls &amp; displays</li>
          </ul>
          <a href="/products/electrical-motors" class="core-link light">Browse equipment parts →</a>
        </div>

        <div class="core-card">
          <div class="core-icon">🔧</div>
          <h3>Fluid &amp; Piping Systems</h3>
          <p>Complete piping solutions — from gate valves and suction pipes to pneumatic fittings and water filtration, supplied per project specification.</p>
          <ul class="core-list">
            <li>Pipes, valves &amp; fittings</li>
            <li>Air-pneumatic components</li>
            <li>Water filtration systems</li>
            <li>Hydraulic hoses &amp; couplings</li>
            <li>Fasteners &amp; structural hardware</li>
            <li>Custom sourcing by part number</li>
          </ul>
          <a href="/products/piping-valves" class="core-link">Browse fluid systems →</a>
        </div>

      </div>
    </section>

    <!-- How it works -->
    <section class="section how-section">
      <div class="container">
        <span class="section-label">Our Process</span>
        <h2 class="section-title">How it works</h2>
        <p class="section-sub">Four simple steps from enquiry to delivery — no price lists, no confusion.</p>

        <div class="steps-grid">
          <div class="step">
            <div class="step-num">01</div>
            <h3 class="step-title">Send your enquiry</h3>
            <p class="step-desc">Share the part name, part number, machine model, or a photo. Use WhatsApp, the quote form, or email — whichever is fastest for you.</p>
          </div>
          <div class="step">
            <div class="step-num">02</div>
            <h3 class="step-title">We confirm availability</h3>
            <p class="step-desc">Our team checks stock and sources from our verified supplier network. We respond within 24 hours with availability and lead time.</p>
          </div>
          <div class="step">
            <div class="step-num">03</div>
            <h3 class="step-title">You receive a quote</h3>
            <p class="step-desc">We send a clear quote with part details, quantity, and total cost — no hidden fees, no obligation to proceed.</p>
          </div>
          <div class="step">
            <div class="step-num">04</div>
            <h3 class="step-title">Delivery to your site</h3>
            <p class="step-desc">Once confirmed, we arrange delivery to Nairobi or across East Africa. Urgent orders can be dispatched same day when stock is available.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Jaynx -->
    <section class="section container">
      <span class="section-label">Why Jaynx</span>
      <h2 class="section-title">What sets us apart</h2>

      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">📦</div>
          <h3>Wide Range</h3>
          <p>Over 100 parts across 16 industrial categories — from conveyor belts to sensors. One supplier for multiple needs.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">⚡</div>
          <h3>Fast Sourcing</h3>
          <p>We don't wait for parts to walk in. Our supplier network lets us source obscure part numbers quickly across Kenya and regionally.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">✅</div>
          <h3>Quality Assured</h3>
          <p>We supply OEM-spec and equivalent parts only — SKF, FAG, NSK, Fleetguard, and other verified brands your engineers trust.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">🤝</div>
          <h3>No Minimum Order</h3>
          <p>Whether you need one seal or a full pallet of belts, we handle orders of any size — no minimums, no fuss.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">📍</div>
          <h3>Nairobi Based</h3>
          <p>Headquartered in Nairobi with fast delivery across Kenya and East Africa. Local knowledge, regional reach.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">💬</div>
          <h3>WhatsApp First</h3>
          <p>Most clients prefer to transact on WhatsApp. We're set up for it — send a photo, get a quote, confirm by message.</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="svc-cta">
      <div class="container svc-cta-inner">
        <div>
          <h2>Ready to source your next part?</h2>
          <p>Share the part details and we'll respond within 24 hours with availability and pricing.</p>
        </div>
        <div class="svc-cta-btns">
          <a href="/contact" class="btn btn-primary">Request a Quote</a>
          <a
            href="https://wa.me/254705954325?text=Hello%20Jaynx%20Enterprises%2C%20I%20need%20a%20quote%20for%20industrial%20parts."
            class="btn btn-wa"
            target="_blank"
            rel="noopener"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.933 7.933 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.898 7.898 0 0 0 13.6 2.326zM7.994 14.521a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592zm3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.729.729 0 0 0-.529.247c-.182.198-.691.677-.691 1.654 0 .977.71 1.916.81 2.049.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232z"/>
            </svg>
            WhatsApp Us
          </a>
        </div>
      </div>
    </section>

  </div>

  <Footer />
</Base>

<style>
  .page-wrap { padding-top: 72px; }

  /* Hero */
  .svc-hero {
    background: linear-gradient(135deg, #f0f4ff 0%, #e6edff 100%);
    border-bottom: 1px solid #dde6ff;
    padding: 80px 0 72px;
    text-align: center;
  }

  .svc-hero-title {
    font-size: clamp(32px, 4.5vw, 56px);
    font-weight: 800;
    color: #111;
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 12px 0 18px;
  }

  .svc-hero-sub {
    font-size: 17px;
    color: #666;
    max-width: 540px;
    margin: 0 auto 32px;
    line-height: 1.7;
  }

  .svc-hero-btns {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Core services */
  .core-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 40px;
    align-items: start;
  }

  .core-card {
    background: #fff;
    border: 1.5px solid #e5e7eb;
    border-radius: 16px;
    padding: 32px 28px;
    position: relative;
  }

  .core-card.featured {
    background: #0e1f3d;
    border-color: #0e1f3d;
    transform: translateY(-8px);
    box-shadow: 0 20px 56px rgba(14,31,61,0.22);
  }

  .core-badge {
    position: absolute;
    top: -13px; left: 50%;
    transform: translateX(-50%);
    background: #f25c2a;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 4px 14px;
    border-radius: 20px;
    white-space: nowrap;
  }

  .core-icon { font-size: 28px; margin-bottom: 16px; }

  .core-card h3 {
    font-size: 18px;
    font-weight: 700;
    color: #0e1f3d;
    margin-bottom: 10px;
  }

  .core-card.featured h3 { color: #fff; }

  .core-card p {
    font-size: 14px;
    color: #666;
    line-height: 1.65;
    margin-bottom: 18px;
  }

  .core-card.featured p { color: rgba(255,255,255,0.65); }

  .core-list {
    list-style: none;
    padding: 0;
    margin: 0 0 22px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .core-list li {
    font-size: 13px;
    color: #333;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .core-list li::before {
    content: "✓";
    font-size: 11px;
    font-weight: 700;
    color: #2563eb;
    background: #eef3ff;
    border-radius: 50%;
    min-width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .core-card.featured .core-list li { color: rgba(255,255,255,0.82); }
  .core-card.featured .core-list li::before { background: rgba(255,255,255,0.12); color: #fff; }

  .core-link {
    font-size: 13px;
    font-weight: 600;
    color: #2563eb;
    text-decoration: none;
  }

  .core-link:hover { text-decoration: underline; }
  .core-link.light { color: #93c5fd; }

  /* Steps */
  .how-section { background: #f7f9ff; }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .step { padding: 4px 0; }

  .step-num {
    font-size: 36px;
    font-weight: 800;
    color: #dbe4ff;
    line-height: 1;
    margin-bottom: 12px;
    font-family: var(--font-display);
  }

  .step-title {
    font-size: 16px;
    font-weight: 700;
    color: #111;
    margin-bottom: 8px;
  }

  .step-desc { font-size: 14px; color: #666; line-height: 1.65; }

  /* Why grid */
  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 40px;
  }

  .why-card {
    background: #f7f9ff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 28px 24px;
  }

  .why-icon { font-size: 28px; margin-bottom: 12px; }

  .why-card h3 {
    font-size: 16px;
    font-weight: 700;
    color: #111;
    margin-bottom: 8px;
  }

  .why-card p { font-size: 14px; color: #666; line-height: 1.65; }

  /* CTA */
  .svc-cta {
    background: #0e1f3d;
    padding: 72px 0;
  }

  .svc-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }

  .svc-cta h2 {
    font-size: clamp(22px, 3vw, 34px);
    font-weight: 800;
    color: #fff;
    margin-bottom: 8px;
  }

  .svc-cta p { font-size: 15px; color: rgba(255,255,255,0.65); }

  .svc-cta-btns { display: flex; gap: 12px; flex-wrap: wrap; flex-shrink: 0; }

  .btn-wa {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 22px;
    background: #16a34a;
    color: #fff;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.2s;
  }

  .btn-wa:hover { background: #15803d; }

  @media (max-width: 900px) {
    .core-grid { grid-template-columns: 1fr; }
    .core-card.featured { transform: none; }
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
    .why-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .steps-grid { grid-template-columns: 1fr; }
    .why-grid { grid-template-columns: 1fr; }
    .svc-cta-inner { flex-direction: column; align-items: flex-start; }
  }
</style>