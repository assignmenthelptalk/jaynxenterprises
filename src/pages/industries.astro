---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Industries Served — Industrial Spare Parts for Kenya & East Africa | Jaynx Enterprises"
  description="Jaynx Enterprises supplies spare parts and industrial equipment to milling, manufacturing, agriculture, mining, food processing, water treatment and more across Kenya and East Africa."
>
  <Navbar />

  <div class="page-wrap">

    <!-- Hero -->
    <section class="ind-hero">
      <div class="container">
        <span class="section-label">Who We Serve</span>
        <h1 class="ind-hero-title">Powering East African industry — across every sector</h1>
        <p class="ind-hero-sub">From Nairobi's manufacturing belt to upcountry milling plants and coastal processing facilities — Jaynx Enterprises keeps operations running with the right parts, sourced fast.</p>
      </div>
    </section>

    <!-- Industries grid -->
    <section class="section container">
      <span class="section-label">Industry Sectors</span>
      <h2 class="section-title">Industries we supply</h2>
      <p class="section-sub">We support operations across these key sectors in Kenya and East Africa.</p>

      <div class="ind-grid">

        <a href="/products/conveyor-belts" class="ind-card">
          <div class="ind-icon">🌾</div>
          <h3>Milling &amp; Grain Processing</h3>
          <p>Conveyor belts, bucket elevator components, bearings, v-belts, and sieving parts for flour mills, grain handlers, and feed mills.</p>
          <div class="ind-tags">
            <span>Conveyor Belts</span>
            <span>Bearings</span>
            <span>V-Belts</span>
          </div>
        </a>

        <a href="/products/electrical-motors" class="ind-card">
          <div class="ind-icon">🏭</div>
          <h3>Manufacturing &amp; Assembly</h3>
          <p>Electrical motors, sensors, controls, fasteners, lubricants, and maintenance supplies for general manufacturing lines across Kenya.</p>
          <div class="ind-tags">
            <span>Motors</span>
            <span>Sensors</span>
            <span>Lubricants</span>
          </div>
        </a>

        <a href="/products/crusher-processing" class="ind-card">
          <div class="ind-icon">⛏️</div>
          <h3>Mining &amp; Quarrying</h3>
          <p>Crusher parts, conveyor components, hydraulic seals, heavy-duty bearings, and structural hardware for quarrying and mining operations.</p>
          <div class="ind-tags">
            <span>Crusher Parts</span>
            <span>Seals</span>
            <span>Bearings</span>
          </div>
        </a>

        <a href="/products/boiler-steam" class="ind-card">
          <div class="ind-icon">☕</div>
          <h3>Food &amp; Beverage Processing</h3>
          <p>Food-grade lubricants, boiler and steam parts, seals, gaskets, valves, and sanitary piping for food processing and bottling plants.</p>
          <div class="ind-tags">
            <span>Boiler Parts</span>
            <span>Seals</span>
            <span>Lubricants</span>
          </div>
        </a>

        <a href="/products/water-filtration" class="ind-card">
          <div class="ind-icon">💧</div>
          <h3>Water &amp; Wastewater Treatment</h3>
          <p>Water filtration systems, pumps, valves, pipes, and separator components for municipal and industrial water treatment facilities.</p>
          <div class="ind-tags">
            <span>Water Filtration</span>
            <span>Piping</span>
            <span>Valves</span>
          </div>
        </a>

        <a href="/products/diesel-filters" class="ind-card">
          <div class="ind-icon">🚜</div>
          <h3>Agriculture &amp; Agro-Processing</h3>
          <p>Diesel engine filters, irrigation pumps, v-belts, bearings, and agro-machinery spare parts for farms and agro-processing plants.</p>
          <div class="ind-tags">
            <span>Diesel Filters</span>
            <span>V-Belts</span>
            <span>Bearings</span>
          </div>
        </a>

        <a href="/products/air-pneumatic" class="ind-card">
          <div class="ind-icon">🏗️</div>
          <h3>Construction &amp; Infrastructure</h3>
          <p>Pneumatic tools, compressor parts, fasteners, structural hardware, and hydraulic hoses for construction sites and infrastructure projects.</p>
          <div class="ind-tags">
            <span>Pneumatics</span>
            <span>Compressors</span>
            <span>Fasteners</span>
          </div>
        </a>

        <a href="/products/separator-decanter" class="ind-card">
          <div class="ind-icon">🧴</div>
          <h3>Oil, Gas &amp; Petrochemical</h3>
          <p>Separator and decanter spare parts, seals, valves, instrumentation, and piping for refinery and petrochemical processing operations.</p>
          <div class="ind-tags">
            <span>Separators</span>
            <span>Valves</span>
            <span>Seals</span>
          </div>
        </a>

        <a href="/products/electrical-motors" class="ind-card">
          <div class="ind-icon">⚡</div>
          <h3>Power &amp; Utilities</h3>
          <p>Motors, electrical components, sensors, controls, and instrumentation for power generation plants and utility infrastructure.</p>
          <div class="ind-tags">
            <span>Motors</span>
            <span>Controls</span>
            <span>Sensors</span>
          </div>
        </a>

        <a href="/products/piping-valves" class="ind-card">
          <div class="ind-icon">🌊</div>
          <h3>Marine &amp; Fishing Industry</h3>
          <p>Corrosion-resistant valves, piping fittings, seals, bearings, and marine-grade hardware for fishing vessels and port facilities.</p>
          <div class="ind-tags">
            <span>Piping</span>
            <span>Valves</span>
            <span>Bearings</span>
          </div>
        </a>

        <a href="/products/compressor-parts" class="ind-card">
          <div class="ind-icon">🏨</div>
          <h3>Hospitality &amp; Facilities</h3>
          <p>Compressor and HVAC parts, water filtration, pumps, and maintenance supplies for hotels, hospitals, and large facility operators.</p>
          <div class="ind-tags">
            <span>Compressors</span>
            <span>Filtration</span>
            <span>Pumps</span>
          </div>
        </a>

        <a href="/products/lubricants" class="ind-card">
          <div class="ind-icon">🔁</div>
          <h3>Transport &amp; Logistics</h3>
          <p>Diesel filters, engine lubricants, belts, bearings, and mechanical parts for fleet maintenance and transport infrastructure.</p>
          <div class="ind-tags">
            <span>Lubricants</span>
            <span>Diesel Filters</span>
            <span>Bearings</span>
          </div>
        </a>

      </div>
    </section>

    <!-- Stats band -->
    <section class="stats-band">
      <div class="container stats-grid">
        <div class="stat">
          <div class="stat-num">16+</div>
          <div class="stat-label">Product Categories</div>
        </div>
        <div class="stat">
          <div class="stat-num">100+</div>
          <div class="stat-label">Part Types Stocked</div>
        </div>
        <div class="stat">
          <div class="stat-num">12+</div>
          <div class="stat-label">Industries Served</div>
        </div>
        <div class="stat">
          <div class="stat-num">24h</div>
          <div class="stat-label">Quote Response Time</div>
        </div>
      </div>
    </section>

    <!-- Custom sourcing callout -->
    <section class="section container">
      <div class="custom-band">
        <div class="custom-copy">
          <h2>Don't see your industry?</h2>
          <p>We source parts across many more sectors. If you have a part number, machine model, or a photo of the component — send it to us and we'll find it.</p>
        </div>
        <div class="custom-actions">
          <a href="/contact" class="btn btn-primary">Request a Quote</a>
          <a
            href="https://wa.me/254705954325?text=Hello%20Jaynx%20Enterprises%2C%20I%20need%20parts%20for%20my%20industry."
            class="btn btn-wa"
            target="_blank"
            rel="noopener"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.933 7.933 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.898 7.898 0 0 0 13.6 2.326zM7.994 14.521a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592zm3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.729.729 0 0 0-.529.247c-.182.198-.691.677-.691 1.654 0 .977.71 1.916.81 2.049.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232z"/>
            </svg>
            WhatsApp Us
          </a>
        </div>
      </div>
    </section>

  </div>

  <Footer />
</Base>

<style>
  .page-wrap { padding-top: 72px; }

  /* Hero */
  .ind-hero {
    background: linear-gradient(135deg, #f0f4ff 0%, #e6edff 100%);
    border-bottom: 1px solid #dde6ff;
    padding: 80px 0 72px;
    text-align: center;
  }

  .ind-hero-title {
    font-size: clamp(30px, 4vw, 52px);
    font-weight: 800;
    color: #111;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 12px auto 18px;
    max-width: 740px;
  }

  .ind-hero-sub {
    font-size: 17px;
    color: #666;
    max-width: 620px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Industries grid */
  .ind-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 40px;
  }

  .ind-card {
    background: #fff;
    border: 1.5px solid #e5e7eb;
    border-radius: 14px;
    padding: 28px 24px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .ind-card:hover {
    border-color: #93c5fd;
    box-shadow: 0 6px 24px rgba(37,99,235,0.10);
    transform: translateY(-3px);
  }

  .ind-icon { font-size: 30px; margin-bottom: 14px; line-height: 1; }

  .ind-card h3 {
    font-size: 16px;
    font-weight: 700;
    color: #111;
    margin-bottom: 8px;
  }

  .ind-card p {
    font-size: 13.5px;
    color: #666;
    line-height: 1.65;
    flex: 1;
    margin-bottom: 16px;
  }

  .ind-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: auto;
  }

  .ind-tags span {
    font-size: 11px;
    font-weight: 600;
    color: #2563eb;
    background: #eef3ff;
    border: 1px solid #c7d7fd;
    border-radius: 999px;
    padding: 3px 10px;
  }

  /* Stats band */
  .stats-band {
    background: #0e1f3d;
    padding: 64px 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    text-align: center;
  }

  .stat-num {
    font-size: clamp(36px, 4vw, 52px);
    font-weight: 800;
    color: #fff;
    font-family: var(--font-display);
    line-height: 1;
    margin-bottom: 8px;
  }

  .stat-label {
    font-size: 13px;
    color: rgba(255,255,255,0.55);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* Custom sourcing band */
  .custom-band {
    background: #f0f4ff;
    border: 1.5px solid #c7d7fd;
    border-radius: 16px;
    padding: 48px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }

  .custom-copy { max-width: 540px; }

  .custom-copy h2 {
    font-size: clamp(20px, 2.5vw, 30px);
    font-weight: 800;
    color: #111;
    margin-bottom: 10px;
  }

  .custom-copy p { font-size: 15px; color: #555; line-height: 1.7; }

  .custom-actions { display: flex; gap: 12px; flex-wrap: wrap; flex-shrink: 0; }

  .btn-wa {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 22px;
    background: #16a34a;
    color: #fff;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.2s;
  }

  .btn-wa:hover { background: #15803d; }

  @media (max-width: 960px) {
    .ind-grid { grid-template-columns: repeat(2, 1fr); }
    .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 32px; }
  }

  @media (max-width: 600px) {
    .ind-grid { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .custom-band { flex-direction: column; align-items: flex-start; padding: 28px 24px; }
  }
</style>