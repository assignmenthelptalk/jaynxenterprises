---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import CatalogSection from '../components/CatalogSection.astro';
import QuoteForm from '../components/QuoteForm.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../config';
import { categories, getProductsByCategory } from '../data/products';
---

<Base>
  <Navbar />
  <Hero />
  <Stats />

  <!-- ── Category quick-nav strip ──────────────────────────────── -->
  <div class="cat-nav-wrap">
    <div class="cat-nav-inner">
      {categories.map(cat => (
        <a href={`#${cat.slug}`} class="cat-nav-pill">
          <span class="cnp-icon" aria-hidden="true">{cat.icon}</span>
          <span class="cnp-label">{cat.name.replace(/ &.*$/, '').replace(/ (Parts|Components|Supplies|System|Systems).*$/, '')}</span>
        </a>
      ))}
    </div>
  </div>

  <!-- ── Product Catalog ───────────────────────────────────────── -->
  <div class="catalog-wrap" id="products">
    <div class="container catalog-intro">
      <span class="section-label">Product Catalogue</span>
      <h2 class="section-title">Browse Our Industrial Spares</h2>
      <p class="section-sub">1,000+ parts across 16 categories. No prices on site — request a quote on any item and we'll respond within 24 hours.</p>
    </div>

    {categories.map(cat => (
      <CatalogSection
        category={cat}
        products={getProductsByCategory(cat.slug)}
      />
    ))}
  </div>

  <!-- ── CTA Banner ─────────────────────────────────────────────── -->
  <div class="cta-banner">
    <div class="container">
      <div class="cta-banner-inner">
        <div class="cta-banner-text">
          <h2>Can't find what you need?</h2>
          <p>Share the part number, machine model, or a photo — we'll source it and come back to you within 24 hours.</p>
        </div>
        <div class="cta-banner-actions">
          <a href="/contact" class="btn btn-primary">Request a Quote</a>
          <a href={`https://wa.me/${SITE.whatsapp}`} class="btn btn-outline btn-outline--white" target="_blank" rel="noopener">WhatsApp Us</a>
        </div>
      </div>
    </div>
  </div>

  <QuoteForm
    id="contact"
    source="homepage"
    title="Get a quote without a long call"
    subtitle="Fill the short form and we will come back with pricing, availability, and next steps."
  />
  <Footer />

  <!-- WhatsApp floating button (desktop) -->
  <a
    href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.ctaWhatsappMessage)}`}
    class="wa-float"
    target="_blank"
    rel="noopener"
    aria-label="Chat on WhatsApp"
    data-conversion="whatsapp"
  >
    <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <!-- Mobile sticky CTA bar -->
  <div class="mobile-sticky-cta">
    <a href="/#contact" class="mobile-sticky-btn mobile-sticky-btn--quote">
      Get Quote
    </a>
    <a
      href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.ctaWhatsappMessage)}`}
      class="mobile-sticky-btn mobile-sticky-btn--whatsapp"
      target="_blank"
      rel="noopener"
      data-conversion="whatsapp"
    >
      <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/>
      </svg>
      WhatsApp
    </a>
  </div>
</Base>

<style>
  /* ── Category quick-nav ─────────────────────────────────────── */
  .cat-nav-wrap {
    background: #fff;
    border-top: 1px solid #e8e8e8;
    border-bottom: 1px solid #e8e8e8;
    position: sticky;
    top: 72px;
    z-index: 50;
  }

  .cat-nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    gap: 4px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
  }

  .cat-nav-inner::-webkit-scrollbar { display: none; }

  .cat-nav-pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 10px 14px;
    font-size: 12.5px;
    font-weight: 600;
    color: #444;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }

  .cat-nav-pill:hover {
    color: #2563eb;
    border-bottom-color: #2563eb;
  }

  .cnp-icon { font-size: 15px; line-height: 1; }
  .cnp-label { line-height: 1; }

  /* ── Catalog ────────────────────────────────────────────────── */
  .catalog-wrap {
    background: #f7f9ff;
  }

  .catalog-intro {
    padding-top: 52px;
    padding-bottom: 8px;
    text-align: center;
  }

  /* ── CTA Banner ─────────────────────────────────────────────── */
  .cta-banner { background: #111; padding: 52px 0; }
  .cta-banner-inner { display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap; }
  .cta-banner-text h2 { font-size: clamp(20px, 2.5vw, 28px); color: #fff; margin-bottom: 8px; }
  .cta-banner-text p { font-size: 15px; color: rgba(255,255,255,0.7); margin: 0; max-width: 520px; }
  .cta-banner-actions { display: flex; gap: 12px; flex-wrap: wrap; flex-shrink: 0; }
  .btn-outline--white { border-color: rgba(255,255,255,0.4); color: #fff; }
  .btn-outline--white:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.7); }

  /* ── WhatsApp float ─────────────────────────────────────────── */
  .wa-float {
    position: fixed;
    bottom: 104px;
    right: 28px;
    z-index: 99;
    width: 56px;
    height: 56px;
    background: #25D366;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(37,211,102,0.4);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
  }

  .wa-float:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 28px rgba(37,211,102,0.5);
  }

  /* ── Mobile sticky CTA ──────────────────────────────────────── */
  .mobile-sticky-cta { display: none; }

  @media (max-width: 900px) {
    .cta-banner-inner { flex-direction: column; align-items: flex-start; }
  }

  @media (max-width: 768px) {
    body { padding-bottom: 112px; }
    .wa-float { display: none; }

    .mobile-sticky-cta {
      position: fixed;
      left: 0; right: 0; bottom: 0;
      z-index: 110;
      display: grid;
      grid-template-columns: 1fr 1.15fr;
      gap: 14px;
      padding: 14px 16px calc(14px + env(safe-area-inset-bottom));
      background: #10233f;
      box-shadow: 0 -10px 24px rgba(16,35,63,0.22);
    }

    .mobile-sticky-btn {
      min-height: 64px;
      border-radius: 12px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-size: 17px;
      font-weight: 800;
      text-decoration: none;
      box-shadow: 0 8px 18px rgba(0,0,0,0.12);
    }

    .mobile-sticky-cta a.mobile-sticky-btn--quote,
    .mobile-sticky-cta a.mobile-sticky-btn--quote:link,
    .mobile-sticky-cta a.mobile-sticky-btn--quote:visited {
      background: #2563eb;
      color: #fff !important;
      text-decoration: none !important;
    }

    .mobile-sticky-cta a.mobile-sticky-btn--whatsapp,
    .mobile-sticky-cta a.mobile-sticky-btn--whatsapp:link,
    .mobile-sticky-cta a.mobile-sticky-btn--whatsapp:visited {
      background: #29d365;
      color: #fff !important;
      text-decoration: none !important;
    }

    .cat-nav-wrap { top: 60px; }
  }
</style>
