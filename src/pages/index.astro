---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import Services from '../components/Services.astro';
import QuoteForm from '../components/QuoteForm.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../config';
import { categories } from '../data/products';

const featuredCategories = categories;
---

<Base>
  <Navbar />
  <Hero />
  <Stats />
  <Services />
  <!-- ── Products Section ──────────────────────────────────────── -->
  <section class="home-products section" id="products">
    <div class="container">
      <div class="hp-header">
        <div>
          <span class="section-label">Product Catalogue</span>
          <h2 class="section-title">Industrial Spares — 16 Categories</h2>
          <p class="section-sub">Over 100 parts for food processing, manufacturing, and industrial machinery. No prices on the site — request a quote on any part.</p>
        </div>
        <a href="/products" class="btn btn-outline hp-all-link">Browse All Categories →</a>
      </div>

      <div class="hp-grid">
        {featuredCategories.map(cat => (
          <a href={`/products/${cat.slug}`} class="hp-card">
            <span class="hp-icon" aria-hidden="true">{cat.icon}</span>
            <span class="hp-name">{cat.name}</span>
          </a>
        ))}
      </div>

      <div class="hp-cta">
        <p>Looking for a specific part? <a href="/contact">Send us the part number →</a></p>
      </div>
    </div>
  </section>

  <!-- ── Why Choose Us ──────────────────────────────────────────── -->
  <section class="why-us section">
    <div class="container">
      <div class="why-header">
        <span class="section-label">Why Jaynx?</span>
        <h2 class="section-title">Built for East Africa's Industry</h2>
      </div>
      <div class="why-grid">
        <div class="why-card">
          <span class="why-icon" aria-hidden="true">🏭</span>
          <h3>Wide Range</h3>
          <p>100+ spare parts spanning conveyor systems, bearings, compressors, motors, boilers, and more — sourced from trusted global manufacturers.</p>
        </div>
        <div class="why-card">
          <span class="why-icon" aria-hidden="true">⚡</span>
          <h3>Fast Sourcing</h3>
          <p>Send us a part number or machine model. We respond within 24 hours with availability, lead time, and a competitive price — no long procurement chains.</p>
        </div>
        <div class="why-card">
          <span class="why-icon" aria-hidden="true">✅</span>
          <h3>Quality Assured</h3>
          <p>Every part is verified against the original specification before dispatch. We stock OEM and premium-grade equivalents — nothing substandard leaves our warehouse.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA Banner ─────────────────────────────────────────────── -->
  <div class="cta-banner">
    <div class="container">
      <div class="cta-banner-inner">
        <div class="cta-banner-text">
          <h2>Can't find what you need?</h2>
          <p>Share the part number, machine model, or a photo — we'll source it and come back to you within 24 hours.</p>
        </div>
        <div class="cta-banner-actions">
          <a href="/contact" class="btn btn-primary">Request a Quote</a>
          <a href={`https://wa.me/${SITE.whatsapp}`} class="btn btn-outline btn-outline--white" target="_blank" rel="noopener">WhatsApp Us</a>
        </div>
      </div>
    </div>
  </div>

  <QuoteForm
    id="contact"
    source="homepage"
    title="Get a quote without a long call"
    subtitle="Fill the short form and we will come back with pricing, availability, and next steps."
  />
  <Footer />

  <!-- WhatsApp floating button (desktop) -->
  <a
    href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.ctaWhatsappMessage)}`}
    class="wa-float"
    target="_blank"
    rel="noopener"
    aria-label="Chat on WhatsApp"
    data-conversion="whatsapp"
  >
    <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <!-- Mobile sticky CTA bar -->
  <div class="mobile-sticky-cta">
    <a href="/#contact" class="mobile-sticky-btn mobile-sticky-btn--quote">
      Get Quote
    </a>
    <a
      href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.ctaWhatsappMessage)}`}
      class="mobile-sticky-btn mobile-sticky-btn--whatsapp"
      target="_blank"
      rel="noopener"
      data-conversion="whatsapp"
    >
      <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/>
      </svg>
      WhatsApp
    </a>
  </div>
</Base>

<style>
  /* Products section */
  .home-products { background: #f7f9ff; }
  .hp-header { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; margin-bottom: 36px; flex-wrap: wrap; }
  .hp-all-link { flex-shrink: 0; }
  .hp-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 28px; }
  .hp-card { display: flex; flex-direction: column; align-items: center; gap: 10px; padding: 22px 16px; background: var(--white); border: 1.5px solid var(--border); border-radius: var(--radius-lg); text-decoration: none; color: inherit; text-align: center; transition: border-color var(--transition), box-shadow var(--transition), transform var(--transition); }
  .hp-card:hover { border-color: var(--accent); box-shadow: 0 4px 16px rgba(37,99,235,0.1); transform: translateY(-2px); text-decoration: none; }
  .hp-icon { font-size: 28px; line-height: 1; }
  .hp-name { font-size: 13px; font-weight: 700; color: var(--dark); line-height: 1.3; }
  .hp-cta { text-align: center; font-size: 14px; color: var(--muted); }
  .hp-cta a { color: var(--accent); font-weight: 600; text-decoration: none; }
  .hp-cta a:hover { text-decoration: underline; }

  /* Why Us section */
  .why-header { text-align: center; margin-bottom: 40px; }
  .why-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .why-card { padding: 28px; background: var(--white); border: 1.5px solid var(--border); border-radius: var(--radius-lg); }
  .why-icon { display: block; font-size: 30px; margin-bottom: 14px; }
  .why-card h3 { font-size: 17px; font-weight: 800; color: var(--dark); margin-bottom: 10px; }
  .why-card p { font-size: 14px; color: var(--muted); line-height: 1.7; margin: 0; }

  /* CTA Banner */
  .cta-banner { background: var(--dark); padding: 52px 0; }
  .cta-banner-inner { display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap; }
  .cta-banner-text h2 { font-size: clamp(20px, 2.5vw, 28px); color: #ffffff; margin-bottom: 8px; }
  .cta-banner-text p { font-size: 15px; color: rgba(255,255,255,0.7); margin: 0; max-width: 520px; }
  .cta-banner-actions { display: flex; gap: 12px; flex-wrap: wrap; flex-shrink: 0; }
  .btn-outline--white { border-color: rgba(255,255,255,0.4); color: #ffffff; }
  .btn-outline--white:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.7); }

  @media (max-width: 900px) {
    .why-grid { grid-template-columns: 1fr; gap: 16px; }
    .cta-banner-inner { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 700px) {
    .hp-grid { grid-template-columns: repeat(2, 1fr); }
    .hp-header { flex-direction: column; align-items: flex-start; }
  }

  .wa-float {
    position: fixed;
    bottom: 104px;
    right: 28px;
    z-index: 99;
    width: 56px;
    height: 56px;
    background: #25D366;
    color: #ffffff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.4);
    transition: transform var(--transition), box-shadow var(--transition);
    text-decoration: none;
  }

  .wa-float:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 28px rgba(37, 211, 102, 0.5);
  }

  .mobile-sticky-cta { display: none; }

  @media (max-width: 768px) {
    body { padding-bottom: 112px; }

    .wa-float { display: none; }

    .mobile-sticky-cta {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 110;
      display: grid;
      grid-template-columns: 1fr 1.15fr;
      gap: 14px;
      padding: 14px 16px calc(14px + env(safe-area-inset-bottom));
      background: #10233f;
      box-shadow: 0 -10px 24px rgba(16, 35, 63, 0.22);
    }

    .mobile-sticky-btn {
      min-height: 64px;
      border-radius: 12px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-size: 17px;
      font-weight: 800;
      text-decoration: none;
      box-shadow: 0 8px 18px rgba(0, 0, 0, 0.12);
    }

    .mobile-sticky-cta a.mobile-sticky-btn--quote,
    .mobile-sticky-cta a.mobile-sticky-btn--quote:link,
    .mobile-sticky-cta a.mobile-sticky-btn--quote:visited {
      background: #2563eb;
      color: #ffffff !important;
      text-decoration: none !important;
    }

    .mobile-sticky-cta a.mobile-sticky-btn--whatsapp,
    .mobile-sticky-cta a.mobile-sticky-btn--whatsapp:link,
    .mobile-sticky-cta a.mobile-sticky-btn--whatsapp:visited {
      background: #29d365;
      color: #ffffff !important;
      text-decoration: none !important;
    }
  }
</style>
