---
import Base from '../../../layouts/Base.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { categories, getProductsByCategory } from '../../../data/products';
import type { Category } from '../../../data/products';

export async function getStaticPaths() {
  return categories.map(cat => ({
    params: { category: cat.slug },
    props: { category: cat },
  }));
}

interface Props {
  category: Category;
}

const { category } = Astro.props;
const categoryProducts = getProductsByCategory(category.slug);
---

<Base
  title={`${category.name} — Industrial Spares | Jaynx Enterprises`}
  description={`${category.description} Request a quote on any part — no prices, just fast sourcing.`}
>
  <Navbar />

  <div class="page-wrap">
    <div class="container">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Products', href: '/products' },
        { label: category.name },
      ]} />

      <header class="page-header">
        <span class="cat-icon" aria-hidden="true">{category.icon}</span>
        <h1 class="section-title">{category.name}</h1>
        <p class="section-sub">{category.description}</p>
        <p class="part-count">{categoryProducts.length} part{categoryProducts.length !== 1 ? 's' : ''} available</p>
      </header>

      <div class="products-grid">
        {categoryProducts.map(product => {
          const specs = product.specifications ? Object.entries(product.specifications).slice(0, 3) : [];
          return (
            <div class="product-card">
              <div class="product-body">
                <h2 class="product-name">
                  <a href={`/products/${category.slug}/${product.id}`}>{product.name}</a>
                </h2>
                <p class="product-desc">{product.description}</p>
                {specs.length > 0 && (
                  <ul class="product-specs">
                    {specs.map(([key, val]) => (
                      <li><span class="spec-key">{key}:</span> {val}</li>
                    ))}
                  </ul>
                )}
              </div>
              <div class="product-actions">
                <a
                  href={`/contact?product=${encodeURIComponent(product.name)}`}
                  class="btn btn-primary btn-sm"
                >
                  Get a Quote
                </a>
                <a href={`/products/${category.slug}/${product.id}`} class="btn btn-outline btn-sm">
                  View Details
                </a>
              </div>
            </div>
          );
        })}
      </div>

      <div class="cta-band">
        <div class="cta-band-inner">
          <div>
            <strong>Need a part not listed here?</strong>
            <p>Share the part number or machine model and we'll source it.</p>
          </div>
          <a href="/contact" class="btn btn-primary">Contact Us</a>
        </div>
      </div>
    </div>
  </div>

  <Footer />
</Base>

<style>
  .page-wrap {
    padding-top: 96px;
    padding-bottom: 80px;
    min-height: 100vh;
  }

  .page-header { padding: 36px 0 44px; }

  .cat-icon {
    font-size: 36px;
    display: block;
    margin-bottom: 12px;
    line-height: 1;
  }

  .page-header h1 { margin-bottom: 10px; }

  .part-count {
    margin-top: 12px;
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 56px;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    background: var(--white);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 24px;
    transition: box-shadow var(--transition), border-color var(--transition);
  }

  .product-card:hover {
    border-color: #c7d7fd;
    box-shadow: 0 4px 16px rgba(37, 99, 235, 0.08);
  }

  .product-body { flex: 1; margin-bottom: 20px; }

  .product-name {
    font-size: 15px;
    font-weight: 700;
    line-height: 1.35;
    margin-bottom: 8px;
  }

  .product-name a {
    color: var(--dark);
    text-decoration: none;
    transition: color var(--transition);
  }

  .product-name a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .product-desc {
    font-size: 13.5px;
    color: var(--muted);
    line-height: 1.65;
    margin-bottom: 14px;
  }

  .product-specs {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .product-specs li {
    font-size: 12.5px;
    color: #555;
    line-height: 1.5;
  }

  .spec-key {
    font-weight: 600;
    color: var(--dark);
  }

  .product-actions { display: flex; gap: 10px; flex-wrap: wrap; }

  .btn-sm { padding: 9px 18px; font-size: 13px; }

  .cta-band {
    background: #eef3ff;
    border: 1.5px solid #c7d7fd;
    border-radius: var(--radius-lg);
    padding: 28px 32px;
  }

  .cta-band-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .cta-band strong {
    display: block;
    font-size: 16px;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 4px;
  }

  .cta-band p { font-size: 14px; color: var(--muted); margin: 0; }
  .cta-band .btn { flex-shrink: 0; }

  @media (max-width: 900px) {
    .products-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .products-grid { grid-template-columns: 1fr; gap: 12px; }
    .product-card { padding: 18px; }
    .cta-band-inner { flex-direction: column; align-items: flex-start; }
    .cta-band { padding: 20px; }
  }
</style>
