---
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { categories, products } from '../../data/products';

const productCounts = Object.fromEntries(
  categories.map(c => [c.slug, products.filter(p => p.category === c.slug).length])
);
---

<Base
  title="Industrial Machine Spares Catalogue | Jaynx Enterprises"
  description="Browse 100+ spare parts across 16 categories: conveyor belts, bearings, v-belts, compressor parts, electrical motors, seals, boiler parts, and more. Request a quote today."
>
  <Navbar />

  <div class="page-wrap">
    <div class="container">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Products' }]} />

      <header class="page-header">
        <span class="section-label">Product Catalogue</span>
        <h1 class="section-title">Industrial Machine Spares</h1>
        <p class="section-sub">
          Over 100 spare parts for food processing, manufacturing, and industrial machinery
          across East Africa. Select a category below, or <a href="/contact">contact us</a> with a
          part number and we'll source it for you.
        </p>
      </header>

      <div class="categories-grid">
        {categories.map(cat => (
          <a href={`/products/${cat.slug}`} class="cat-card">
            <span class="cat-icon" aria-hidden="true">{cat.icon}</span>
            <div class="cat-body">
              <h2 class="cat-name">{cat.name}</h2>
              <p class="cat-desc">{cat.description}</p>
            </div>
            <div class="cat-footer">
              <span class="cat-count">{productCounts[cat.slug]} part{productCounts[cat.slug] !== 1 ? 's' : ''}</span>
              <span class="cat-arrow" aria-hidden="true">→</span>
            </div>
          </a>
        ))}
      </div>

      <div class="cta-band">
        <div class="cta-band-inner">
          <div>
            <strong>Can't find what you need?</strong>
            <p>Share the part number or machine model and we'll source it for you.</p>
          </div>
          <a href="/contact" class="btn btn-primary">Get in Touch</a>
        </div>
      </div>
    </div>
  </div>

  <Footer />
</Base>

<style>
  .page-wrap {
    padding-top: 96px;
    padding-bottom: 80px;
    min-height: 100vh;
  }

  .page-header {
    padding: 40px 0 48px;
    max-width: 640px;
  }

  .page-header h1 { margin-bottom: 12px; }

  .page-header a {
    color: var(--accent);
    text-decoration: underline;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 60px;
  }

  .cat-card {
    display: flex;
    flex-direction: column;
    background: var(--white);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 24px;
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition), box-shadow var(--transition), transform var(--transition);
  }

  .cat-card:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 20px rgba(37, 99, 235, 0.1);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .cat-icon {
    font-size: 30px;
    line-height: 1;
    margin-bottom: 14px;
    display: block;
  }

  .cat-body { flex: 1; }

  .cat-name {
    font-size: 15px;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 8px;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .cat-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .cat-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 12px;
    border-top: 1px solid var(--border);
    margin-top: auto;
  }

  .cat-count {
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
  }

  .cat-arrow {
    font-size: 15px;
    color: var(--muted);
    transition: transform var(--transition), color var(--transition);
  }

  .cat-card:hover .cat-arrow {
    transform: translateX(4px);
    color: var(--accent);
  }

  .cta-band {
    background: #eef3ff;
    border: 1.5px solid #c7d7fd;
    border-radius: var(--radius-lg);
    padding: 28px 32px;
  }

  .cta-band-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .cta-band strong {
    display: block;
    font-size: 16px;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 4px;
  }

  .cta-band p { font-size: 14px; color: var(--muted); margin: 0; }
  .cta-band .btn { flex-shrink: 0; }

  @media (max-width: 1000px) {
    .categories-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 700px) {
    .categories-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .cat-card { padding: 18px; }
    .cta-band-inner { flex-direction: column; align-items: flex-start; }
  }

  @media (max-width: 400px) {
    .categories-grid { grid-template-columns: 1fr; }
  }
</style>
